# Backend Configuration Template
PORT=3001
NODE_ENV=development

# Database Configuration (PostgreSQL / SQLite)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lelang_db
DB_USER=lelang_user
DB_PASSWORD=your_secure_password_here

# Blockchain RPC (untuk fallback ZKP server-side / verifikasi)
CHAIN_RPC_URL=http://localhost:26657
CHAIN_ID=lelang-testnet

# JWT Secret (untuk session management)
JWT_SECRET=your_jwt_secret_key_here

# Image Upload Configuration
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# CORS Origin Allowed
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3000
